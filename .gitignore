# === FRONTEND (Next.js) ===
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
# Игнорируем логи и системные файлы npm/yarn
frontend/.pnpm-debug.log*
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# === BACKEND (Django) ===
# Игнорируем весь кэш Python рекурсивно
**/__pycache__/
*.py[cod]
*$py.class

# Окружение
backend/venv/
backend/env/
backend/ENV/
backend/.env

# База данных
backend/db.sqlite3
backend/db.sqlite3-journal

# Медиа и статика (собираемая)
backend/media/
backend/static/
!backend/static/.gitkeep
backend/static_collected/

# === ОБЩЕЕ ===
# Файлы Repomix и отчеты
repomix-output.xml
*-output.xml

# Переменные окружения (все уровни)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Замки пакетов (если хочешь оставить их в репо — закомментируй эти строки)
# Обычно package-lock.json лучше ХРАНИТЬ в репо для стабильности билда
# package-lock.json
# pnpm-lock.yaml
# yarn.lock

# IDE / Системные файлы
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.swp

# Тесты
/coverage
.nyc_output
.pytest_cache/